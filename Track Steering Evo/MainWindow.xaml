<Window x:Class="Track_Steering_Evo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Track_Steering_Evo"
        mc:Ignorable="d"
Title="Raytracing RaceCars" Height="1000" Width="2000" Loaded="Window_Loaded" Closing="Window_Closing" WindowState="Maximized">
    <Grid Background="lightGray" >
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="0.4*"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="0.4*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Menu Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <MenuItem Header="File">
                <MenuItem Header="Load Vehicle" Name="MnuLoad" Click="MnuLoad_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Save Best Vehicle" Name="MnuSaveBest" Click="MnuSaveBest_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Exit" Name="MnuExit" Click="MnuExit_Click"></MenuItem>
            </MenuItem>
        </Menu>
        <Canvas Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Name="canvas1" Background="Green" Margin="0,0,2,0"></Canvas>
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Blue" BorderThickness="5" Margin="15">
            <Canvas  Name="canvas2" Background="black" Margin="2,0,0,0" ClipToBounds="True"></Canvas>
        </Border>
        <Border Grid.Row="2" Grid.Column="1" BorderBrush="Blue" BorderThickness="5" Margin="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <GroupBox Grid.Row="0" Grid.Column="0" Header="Vehicle Parameters:" Margin="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Margin="5">Population Size</Label>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Width="80" Name="TxtPopSize"></TextBox>
                        <Label Grid.Row="1" Grid.Column="0" Margin="5">Vehicle Speed</Label>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Width="80" Name="TxtVehicleSpeed"></TextBox>
                        <Label Grid.Row="2" Grid.Column="0" Margin="5">Vehicle Maximum Turn</Label>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Width="80" Name="TxtVehicleTurn"></TextBox>
                        <Label Grid.Row="3" Grid.Column="0" Margin="5">Vehicle Field of View</Label>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="5" Width="80" Name="TxtVehicleFOV"></TextBox>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Row="0" Grid.Column="1" Header="Track Parameters:" Margin="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Margin="5">Twisting factor (0.0 - 1.3)</Label>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Width="80" Name="TxtTrackTwist"></TextBox>
                        <Label Grid.Row="1" Grid.Column="0" Margin="5">Track Average Width</Label>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Width="80" Name="TxtTrackWidth"></TextBox>
                        <Label Grid.Row="2" Grid.Column="0" Margin="5">Track Laps per Race</Label>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Width="80" Name="TxtTrackLaps"></TextBox>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Row="1" Grid.Column="0" Header="Neural Net Parameters:" Margin="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Margin="5">Hidden layer Nodes</Label>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Width="80" Name="TxtNNHidden"></TextBox>
                        <Label Grid.Row="1" Grid.Column="0" Margin="5">Output Nodes</Label>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Width="80" Name="TxtNNOutput"></TextBox>
                        <Label Grid.Row="2" Grid.Column="0" Margin="5">Mutation Rate %</Label>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Width="80" Name="TxtNNMutationRate"></TextBox>
                        <Label Grid.Row="3" Grid.Column="0" Margin="5">Mutation Change %</Label>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="5" Width="80" Name="TxtNNMutationChange"></TextBox>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Row="1" Grid.Column="1" Header="Best Car Parameters:" Margin="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Margin="5">Turn Speed</Label>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Width="80" Name="TxtCarTurn"></TextBox>
                        <Label Grid.Row="1" Grid.Column="0" Margin="5">Current Speed</Label>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Width="80" Name="TxtCarSpeed"></TextBox>
                    </Grid>
                </GroupBox>
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" >
                    <Button Margin="20" Width="80" Height="30" FontSize="14" FontWeight="Bold" Name="BtnStart" Click="BtnStart_Click">START</Button>
                    <Button Margin="40,20" Width="80" Height="30" FontSize="14" FontWeight="Bold" Name="BtnStop" Click="BtnStop_Click">STOP</Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
