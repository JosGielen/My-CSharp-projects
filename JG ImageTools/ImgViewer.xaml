<Window x:Class="ImageTools.ImgViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageTools"
        mc:Ignorable="d"
        Title="Image Viewer" Height="900" Width="1000" Loaded="Window_Loaded" Closing="Window_Closing" KeyUp="Window_KeyUp">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="Open Image..." Name="MnuOpen" Click="MnuOpen_Click"></MenuItem>
                <MenuItem Header="Save Image" Name="MnuSave" Click="MnuSave_Click"></MenuItem>
                <MenuItem Header="Save Image As..." Name="MnuSaveAs" Click="MnuSaveAs_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Print Image..." Name="MnuPrint" Click="MnuPrint_Click"></MenuItem>
                <MenuItem Header="Close" Name="MnuClose" Click="MnuClose_Click"></MenuItem>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Copy" Name="MnuCopy" Click="MnuCopy_Click"></MenuItem>
                <MenuItem Header="Paste" Name="MnuPaste" Click="MnuPaste_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Restore Image" Name="MnuRestore" Click="MnuRestore_Click"></MenuItem>
            </MenuItem>
            <MenuItem Header="Measure" Name="MnuMeasure">
                <MenuItem Header="Arrow" Name="MnuEdit" Click="MnuEdit_Click" IsCheckable="True" IsChecked="True" ></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Line (2 Points)" Name="MnuLine" Click="MnuLine_Click" IsCheckable="True"></MenuItem>
                <MenuItem Header="Rectangle (2 Points)" Name="MnuRectangle" Click="MnuRectangle_Click" IsCheckable="True"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Ellipse (2 Points)" Name="MnuEllipse" Click="MnuEllipse_Click" IsCheckable="True"></MenuItem>
                <MenuItem Header="Circle (3 Points)" Name="MnuCircle" Click="MnuCircle_Click" IsCheckable="True"></MenuItem>
                <MenuItem Header="Circle (Center + Radius)" Name="MnuCircle2" Click="MnuCircle2_Click" IsCheckable="True"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Angle (Center + 2 Points)" Name="MnuAngle" Click="MnuAngle_Click" IsCheckable="True"></MenuItem>
                <MenuItem Header="Angle (2 Lines)" Name="MnuAngle2" Click="MnuAngle2_Click" IsCheckable="True"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Caliper (Line + Distance)" Name="MnuCaliper" Click="MnuCaliper_Click" IsCheckable="True"></MenuItem>
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Edit Image..." Name="MnuEditImage" Click="MnuEditImage_Click" ></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Options..." Name="MnuOptions" Click="MnuOptions_Click" ></MenuItem>
            </MenuItem>
            <MenuItem Header="Main Window" Name="MnuMainWindow" Click="MnuMainWindow_Click"></MenuItem>
            <MenuItem Header="Image Editor" Name="MnuEditorWindow" Click="MnuEditorWindow_Click"></MenuItem>
        </Menu>
        <Grid Grid.Row="1" Background="LightGray">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Margin="4" BorderBrush="Blue" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Name="btnZoomOut" Width="25" Height="25" Margin="3" Click="btnZoomOut_Click" >
                        <Image Name="imgZoomOut"></Image>
                    </Button>
                    <TextBox Grid.Column="1" Width="50" Height="25" Name="txtCurrentZoom" Margin="3" FontFamily="Times New Roman" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></TextBox>
                    <Button Grid.Column="2" Name="btnZoomIn" Width="25" Height="25" Margin="3" Click="btnZoomIn_Click">
                        <Image Name="imgZoomIn"></Image>
                    </Button>
                </Grid>
            </Border>
            <Button Grid.Column="1" Margin="4" Name="BtnEditTool" Click="BtnEditTool_Click" >
                <Image Name="imgEditTool"></Image>
            </Button>
            <Button Grid.Column="2" Margin="4" Name="BtnLineTool" Click="BtnLineTool_Click">
                <Image Name="imgLineTool"></Image>
            </Button>
            <Button Grid.Column="3" Margin="4" Name="BtnRectangleTool" Click="BtnRectangleTool_Click">
                <Image Name="imgRectangleTool"></Image>
            </Button>
            <Button Grid.Column="6" Margin="4" Name="BtnEllipseTool" Click="BtnEllipseTool_Click">
                <Image Name="imgEllipseTool"></Image>
            </Button>
            <Button Grid.Column="4" Margin="4" Name="BtnCirleTool" Click="BtnCirleTool_Click">
                <Image Name="imgCircleTool"></Image>
            </Button>
            <Button Grid.Column="5" Margin="4" Name="BtnCircle2Tool" Click="BtnCircle2Tool_Click">
                <Image Name="imgCircle2Tool"></Image>
            </Button>
            <Button Grid.Column="7" Margin="4" Name="BtnAngleTool" Click="BtnAngleTool_Click">
                <Image Name="imgAngleTool"></Image>
            </Button>
            <Button Grid.Column="8" Margin="4" Name="BtnAngle2Tool" Click="BtnAngle2Tool_Click">
                <Image Name="imgAngle2Tool"></Image>
            </Button>
            <Button Grid.Column="9" Margin="4" Name="BtnCaliperTool" Click="BtnCaliperTool_Click">
                <Image Name="imgCaliperTool"></Image>
            </Button>
            <StackPanel Grid.Column="10" Margin="15" Orientation="Horizontal">
                <Label >Image:</Label>
                <TextBox Width="auto" Name="TxtImageName" FontSize="12" VerticalContentAlignment="Center"></TextBox>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="10" Orientation="Horizontal" HorizontalAlignment="Left" />
                <StackPanel Grid.Row="2" Margin="10" Orientation="Horizontal" HorizontalAlignment="Left" />
                <StackPanel Grid.Row="3" Margin="15,10" Orientation="Horizontal" HorizontalAlignment="Center" />
            </Grid>
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Name="ScrlViewer" Background="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <Canvas Name="canvas1" MouseLeftButtonDown="canvas1_MouseLeftButtonDown" MouseMove="canvas1_MouseMove" MouseLeftButtonUp="canvas1_MouseLeftButtonUp"></Canvas>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
