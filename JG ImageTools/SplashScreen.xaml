<Window x:Class="ImageTools.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageTools"
        mc:Ignorable="d"
        Title="" Height="450" Width="800" Background="Bisque" WindowStartupLocation="CenterScreen" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" FontSize="48" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center">JG IMAGE TOOLS</Label>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <Label FontSize="32">An application for showing, modifying and</Label>
            <Label FontSize="32" HorizontalAlignment="Center">measuring images.</Label>
        </StackPanel>
        <Label Grid.Row="2" FontSize="22" Margin="25">Programmed by Jos Gielen in C#.</Label>
    </Grid>
</Window>
