<Window x:Class="ImageTools.PictureControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Lib1="clr-namespace:JG_Graphs;assembly=JG_Graphs"
    xmlns:Lib2="clr-namespace:RubberBand;assembly=RubberBand"
    Title="Image Editor" Height="1000" Width="1200" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition ></ColumnDefinition>
            <ColumnDefinition Width="auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <!-- Menu -->
        <Menu Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <MenuItem Header="File">
                <MenuItem Header="Open Image..." Name="MnuOpen" Click="MnuOpen_Click"></MenuItem>
                <MenuItem Header="Save Image" Name="MnuSave" Click="MnuSave_Click"></MenuItem>
                <MenuItem Header="Save Image As..." Name="MnuSaveAs" Click="MnuSaveAs_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Print Image..." Name="MnuPrint" Click="MnuPrint_Click"></MenuItem>
                <MenuItem Header="Close" Name="MnuClose" Click="MnuClose_Click"></MenuItem>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Copy" Name="MnuCopy" Click="MnuCopy_Click"></MenuItem>
                <MenuItem Header="Paste" Name="MnuPaste" Click="MnuPaste_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Restore" Name="MnuRestore" Click="MnuRestore_Click"></MenuItem>
            </MenuItem>
            <MenuItem Header="Main Window" Name="MnuMainWindow" Click="MnuMainWindow_Click"></MenuItem>
            <MenuItem Header="Image Viewer" Name="MnuMeasure" Click="MnuMeasure_Click" ></MenuItem>
        </Menu>
        <!-- Full Image -->
        <Border Grid.Row="2" Grid.Column="0" BorderBrush="Blue" BorderThickness="2" Margin="5" Name="CurrentBorder">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Name="ScrlViewer" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <Canvas Name="CurrentCanvas" Background="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}" SnapsToDevicePixels="true" MouseLeftButtonDown="CurrentCanvas_MouseLeftButtonDown" MouseMove="CurrentCanvas_MouseMove" MouseLeftButtonUp="CurrentCanvas_MouseLeftButtonUp">
                    <Lib2:RubberBand Name="CropBand" Stroke="Red" ShowCorners="False"/>
                    <Line Name="MyLine" Stroke="Red" StrokeThickness="1"></Line>
                </Canvas>
            </ScrollViewer>
        </Border>
        <!-- Side column with the tools. -->
        <TabControl Grid.Row="1" Grid.RowSpan="3" Grid.Column="1" Name="TControl1" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Image control">
                <Grid Grid.Row="0" Grid.Column="1" Width="300">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <!-- Preview Image -->
                    <Border Grid.Row="0" BorderBrush="Blue" BorderThickness="1" Margin="5" Height="200">
                        <Canvas Name="PreviewCanvas" Background="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}" SnapsToDevicePixels="True"/>
                    </Border>
                    <!-- Apply to original Image-->
                    <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Width="130" Height="25" Margin="5" Name="BtnApply" Click="BtnApply_Click">APPLY TO ORIGINAL</Button>
                    <!-- Brightness, Contrast, etc Sliders -->
                    <Border Grid.Row="2" BorderBrush="Blue" BorderThickness="1" Margin="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <GroupBox Grid.Row="0" Header="Brightness" Margin="3,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Name="SldBrightness" LargeChange="10" SmallChange="1" Maximum="255" Minimum="-255" IsSnapToTickEnabled="True" ValueChanged="SldBrightness_ValueChanged"></Slider>
                                    <TextBox Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Width="40" Height="20" HorizontalContentAlignment="Center" Margin="3" Text="{Binding ElementName=SldBrightness, Path=Value}"></TextBox>
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Row="1" Header="Contrast" Margin="3,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Name="SldContrast" LargeChange="10" SmallChange="1" Maximum="127" Minimum="-127" IsSnapToTickEnabled="True" ValueChanged="SldContrast_ValueChanged"></Slider>
                                    <TextBox Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Width="40" Height="20" HorizontalContentAlignment="Center" Margin="3" Text="{Binding ElementName=SldContrast , Path=Value}"></TextBox>
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Row="2" Header="Gamma" Margin="3,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Name="SldGamma" LargeChange="1" SmallChange="0.1" Maximum="10" Minimum="-10" Value="0" ValueChanged="SldGamma_ValueChanged"></Slider>
                                    <TextBox Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Width="40" Height="20" HorizontalContentAlignment="Center" Margin="3" Name="TxtGamma">1</TextBox>
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Row="3" Header="Saturation" Margin="3,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Name="SldSaturation" LargeChange="10" SmallChange="1" Maximum="255" ValueChanged="SldSaturation_ValueChanged" TickFrequency="0.1" Minimum="-255"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Width="40" Height="20" HorizontalContentAlignment="Center" Margin="3" Text="{Binding ElementName=SldSaturation, Path=Value}" ></TextBox>
                                </Grid>
                            </GroupBox>
                            <Grid Grid.Row="4" Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Row="0" Grid.Column="0" Width="60" Height="25" Margin="5" Name="BtnReset" Click="BtnReset_Click">RESET</Button>
                                <Button Grid.Row="0" Grid.Column="1" Width="60" Height="25" Margin="5" Name="BtnInverse" Click="BtnInverse_Click">INVERSE</Button>
                            </Grid>
                        </Grid>
                    </Border>
                    <!-- Brightness/Contrast canvas-->
                    <Border Grid.Row="3" BorderBrush="Blue" BorderThickness="1" Margin="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" VerticalAlignment="Top" >
                                <Label.LayoutTransform>
                                    <RotateTransform Angle="270"/>
                                </Label.LayoutTransform>
                                <Label.Content>Brightness</Label.Content>
                            </Label>
                            <Label Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Right" Padding="5,0" Margin="0,5" >Contrast</Label>
                            <Border Grid.Row="1" Grid.Column="1" Margin="0,10,10,0" BorderBrush="Black" BorderThickness="2" >
                                <Canvas Name="ControlCanvas" MouseLeftButtonDown="ControlCanvas_MouseLeftButtonDown" MouseMove="ControlCanvas_MouseMove" MouseLeftButtonUp="ControlCanvas_MouseLeftButtonUp" Background="WhiteSmoke" Height="160" ></Canvas>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- Intensity histogram-->
                    <Border Grid.Row="4" Margin="5" BorderBrush="Blue" BorderThickness="1">
                        <Lib1:ScatterGraph Name="ResultGraph" AllowSettings="False" Height="210"></Lib1:ScatterGraph>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Image manipulation">
                <Grid Grid.Row="0" Grid.Column="1" Width="300">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <!-- Image Rotation-->
                    <GroupBox Grid.Row="3" Header="Rotate Image:" Margin="8" BorderThickness="2" BorderBrush="Blue">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Margin="5,10,5,5" Name="BtnRotLeft" Click="BtnRotLeft_Click" >Rotate 90° C.C.W.</Button>
                            <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Margin="5,10,5,5" Name="BtnFlipHorizontal" Click="BtnFlipHorizontal_Click">Flip Horizontal</Button>
                            <Button Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Margin="5" Name="BtnRotRight" Click="BtnRotRight_Click">Rotate 90° C.W.</Button>
                            <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Margin="5" Name="BtnFlipVertical" Click="BtnFlipVertical_Click">Flip Vertical</Button>
                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"></ColumnDefinition>
                                    <ColumnDefinition  Width="auto"></ColumnDefinition>
                                    <ColumnDefinition  Width="auto"></ColumnDefinition>
                                    <ColumnDefinition  Width="auto"></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Margin="15,5,1,5">Custom Angle:</Label>
                                <TextBox Grid.Column="1" Margin="2,5,0,5" Width="40" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MaxLines="1" Name="TxtDegrees">0.0</TextBox>
                                <Label Grid.Column="2" Width="60" Margin="0,5,5,5" >Degrees</Label>
                                <Button Grid.Column="3" Margin="5" MinWidth="40" Name="BtnCustomRotate" Click="BtnCustomRotate_Click">Rotate</Button>
                            </Grid>
                        </Grid>
                    </GroupBox>
                    <!-- Image Rotate to Line -->
                    <GroupBox Grid.Row="4" Header="Rotate to Horizontal or Vertical Line:" Margin="8" BorderThickness="2" BorderBrush="Blue">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="120" Margin="5,10,5,5" Name="BtnSelectHorizontal" Click="BtnSelectHorizontal_Click">Draw Horizontal Line</Button>
                            <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="120" Margin="5,10,5,5" Name="BtnSelectVertical" Click="BtnSelectVertical_Click">Draw Vertical Line</Button>
                            <Button Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Margin="0,15,0,8" IsEnabled="False"  Name="BtnRotateToLine" Click="BtnRotateToLine_Click">Rotate to Line</Button>
                            <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Margin="0,15,0,8" Name="BtnCancelRotate" Click="BtnCancelRotate_Click" >Cancel</Button>
                        </Grid>
                    </GroupBox>
                    <!-- Image smoothing/sharpen-->
                    <GroupBox Grid.Row="5" Header="Image Quality:" Margin="8" Padding="0" BorderThickness="2" BorderBrush="Blue">
                        <Grid Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <GroupBox Grid.Row="0" Header="Smooth Image:" Margin="0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" Margin="5,0" Minimum="0" Maximum="10" Name="SldSmoothValue" Value="1" SmallChange="1" IsSnapToTickEnabled="True" Padding="1"></Slider>
                                    <TextBox Grid.Column="1" Margin="5,0" Width="40" Text="{Binding ElementName=SldSmoothValue, Path=Value}"></TextBox>
                                    <Button Grid.Column="2" Margin="5,0" Width="60" Name="BtnSmooth" Click="BtnSmooth_Click" HorizontalAlignment="Center" VerticalAlignment="Center">Smooth</Button>
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Row="1" Header="Sharpen Image:" Margin="0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" Margin="5,0" Minimum="0" Maximum="1" Name="SldSharpenValue" LargeChange="0.1" Value="0.5" IsSnapToTickEnabled="True" TickFrequency="0.1" Padding="1"></Slider>
                                    <TextBox Grid.Column="1" Margin="5,0" Width="40" Text="{Binding ElementName=SldSharpenValue, Path=Value}"></TextBox>
                                    <Button Grid.Column="2" Margin="5,0" Width="60" Name="BtnSharpen" Click="BtnSharpen_Click" HorizontalAlignment="Center" VerticalAlignment="Center">Sharpen</Button>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </GroupBox>
                    <GroupBox Grid.Row="6" Header="Crop Image:" Margin="8" Padding="0" BorderThickness="2" BorderBrush="Blue">
                        <Grid Margin="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" Width="100" Height="30" Margin="0,5" Name="BtnSelectCrop" Click="BtnSelectCrop_Click" >Select Crop Area</Button>
                            <Button Grid.Row="0" Grid.Column="1" Width="100" Height="30" Margin="0,5" Name="BtnCropImage" Click="BtnCropImage_Click" IsEnabled="False">Crop Image</Button>
                            <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="20,17,20,5" Name="CbKeepAspect" Click="CbKeepAspect_Click">Keep Aspect Ratio</CheckBox>
                            <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Margin="0,15,0,8" Name="BtnCancelCrop" Click="BtnCancelCrop_Click">Cancel</Button>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
