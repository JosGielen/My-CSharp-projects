<Window x:Class="STL_Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:JG="clr-namespace:JG_GL;assembly=JG_GL"
        mc:Ignorable="d"
        Title="MainWindow" Height="1000" Width="1200" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="0.38*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Menu Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <MenuItem Header="File">
                <MenuItem Header="Open STL File" Name="MnuOpenSTL" Click="MnuOpenSTL_Click" ></MenuItem>
                <MenuItem Header="Open Vertex File" Name="MnuOpenVertex" Click="MnuOpenVertex_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Exit" Name="MnuExit" Click="MnuExit_Click" ></MenuItem>
            </MenuItem>
            <MenuItem Header="Show Geometry">
                <MenuItem Header="Box" Name="MnuShowBox" Click="MnuShowBox_Click" ></MenuItem>
                <MenuItem Header="Cone" Name="MnuShowCone" Click="MnuShowCone_Click"></MenuItem>
                <MenuItem Header="Cylinder" Name="MnuShowCyl" Click="MnuShowCyl_Click" ></MenuItem>
                <MenuItem Header="3DLine" Name="MnuShow3DLine" Click="MnuShow3DLine_Click" ></MenuItem>
                <MenuItem Header="Dodecahedron" Name="MnuShowDodec" Click="MnuShowDodec_Click" ></MenuItem>
                <MenuItem Header="Ellipsoid" Name="MnuShowEllips" Click="MnuShowEllips_Click" ></MenuItem>
                <MenuItem Header="Icosahedron" Name="MnuShowIcosa" Click="MnuShowIcosa_Click" ></MenuItem>
                <MenuItem Header="Line" Name="MnuShowLine" Click="MnuShowLine_Click" ></MenuItem>
                <MenuItem Header="Mesh" Name="MnuShowMesh" Click="MnuShowMesh_Click" ></MenuItem>
                <MenuItem Header="PolyLine" Name="MnuShowPLine" Click="MnuShowPLine_Click" ></MenuItem>
                <MenuItem Header="PolyLineRotation" Name="MnuShowPLineRot" Click="MnuShowPLineRot_Click" ></MenuItem>
                <MenuItem Header="Text" Name="MnuShowText" Click="MnuShowText_Click" ></MenuItem>
                <MenuItem Header="Torus" Name="MnuShowTorus" Click="MnuShowTorus_Click" ></MenuItem>
                <MenuItem Header="Trefoil" Name="MnuShowTreFoil" Click="MnuShowTreFoil_Click" ></MenuItem>
                <MenuItem Header="Tube" Name="MnuShowTube" Click="MnuShowTube_Click" ></MenuItem>
                <MenuItem Header="UserDefined" Name="MnuShowUserDef" Click="MnuShowUserDef_Click" ></MenuItem>
            </MenuItem>
        </Menu>
        <JG:GLScene Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Margin="5" x:Name="Scene1" ></JG:GLScene>
        <GroupBox Grid.Row="1" Grid.Column="1"  Header="Object Parameters:" Margin="8" BorderBrush="Blue" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Padding="3,5,5,5"  HorizontalAlignment="Right" Margin="0,5,0,0">Draw Mode:</Label>
                <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Width="100" HorizontalAlignment="Left" SelectedIndex="0" Name="CmbGeometryDrawMode" SelectionChanged="CmbGeometryDrawMode_SelectionChanged">
                    <ComboBoxItem>Filled</ComboBoxItem>
                    <ComboBoxItem>Lines</ComboBoxItem>
                    <ComboBoxItem>Points</ComboBoxItem>
                </ComboBox>
                <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Padding="3,5,5,5"  HorizontalAlignment="Right" Margin="0,5,0,0">Position:</Label>
                <Border Grid.Row="1" Grid.Column="1" BorderBrush="blue" BorderThickness="1" CornerRadius="5" Padding="5,0,3,0" Margin="0,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="1" Padding="0,6,0,5">X:</Label>
                        <TextBox Grid.Column="2" Width="30" Margin="5" Height="22" Name="TxtGeometryPosX" TextChanged="TxtGeometryPos_TextChanged"></TextBox>
                        <Label Grid.Column="3" Padding="0,6,0,5">Y:</Label>
                        <TextBox Grid.Column="4" Width="30" Margin="5" Height="22" Name="TxtGeometryPosY" TextChanged="TxtGeometryPos_TextChanged"></TextBox>
                        <Label Grid.Column="5" Padding="0,6,0,5">Z:</Label>
                        <TextBox Grid.Column="6" Width="30" Margin="5" Height="22" Name="TxtGeometryPosZ" TextChanged="TxtGeometryPos_TextChanged"></TextBox>
                    </Grid>
                </Border>
                <Label Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Padding="3,5,5,5" HorizontalAlignment="Right">Initial Rotation:</Label>
                <Border Grid.Row="2" Grid.Column="1" BorderBrush="blue" BorderThickness="1" CornerRadius="5" Padding="5,0,3,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="1" Padding="0,6,0,5">X:</Label>
                        <TextBox Grid.Column="2" Width="30" Margin="5" Height="22" Name="TxtGeometryInitRotX" TextChanged="TxtGeometryInitRot_TextChanged"></TextBox>
                        <Label Grid.Column="3" Padding="0,6,0,5">Y:</Label>
                        <TextBox Grid.Column="4" Width="30" Margin="5" Height="22" Name="TxtGeometryInitRotY" TextChanged="TxtGeometryInitRot_TextChanged"></TextBox>
                        <Label Grid.Column="5" Padding="0,6,0,5">Z:</Label>
                        <TextBox Grid.Column="6" Width="30" Margin="5" Height="22" Name="TxtGeometryInitRotZ" TextChanged="TxtGeometryInitRot_TextChanged"></TextBox>
                    </Grid>
                </Border>
                <Label Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Padding="3,5,5,5" HorizontalAlignment="Right">Rotation Axis:</Label>
                <Border Grid.Row="3" Grid.Column="1" BorderBrush="blue" BorderThickness="1" CornerRadius="5" Padding="5,0,3,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="1" Padding="0,6,0,5">X:</Label>
                        <TextBox Grid.Column="2" Width="30" Margin="5" Height="22" Name="TxtGeometryRotAxisX" TextChanged="TxtGeometryRotAxis_TextChanged"></TextBox>
                        <Label Grid.Column="3" Padding="0,6,0,5">Y:</Label>
                        <TextBox Grid.Column="4" Width="30" Margin="5" Height="22" Name="TxtGeometryRotAxisY" TextChanged="TxtGeometryRotAxis_TextChanged"></TextBox>
                        <Label Grid.Column="5" Padding="0,6,0,5">Z:</Label>
                        <TextBox Grid.Column="6" Width="30" Margin="5" Height="22" Name="TxtGeometryRotAxisZ" TextChanged="TxtGeometryRotAxis_TextChanged"></TextBox>
                    </Grid>
                </Border>
                <Label Grid.Row="4" Grid.Column="0" HorizontalAlignment="Center" Padding="5,8,5,5" VerticalAlignment="Center">Rotation Speed:</Label>
                <TextBox Grid.Row="4" Grid.Column="1" Height="22" Width="40" HorizontalAlignment="Left" Name="TxtGeometryRotSpeed" TextChanged="TxtGeometryRotSpeed_TextChanged" Margin="5,0,0,0" VerticalAlignment="Center"></TextBox>
                <Label Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Padding="3,5,5,5" Margin="0,15,0,0" HorizontalAlignment="Right">Ambient Material:</Label>
                <Border Grid.Row="5" Grid.Column="1" BorderBrush="blue" BorderThickness="1" CornerRadius="5" Padding="5,0,3,0" Margin="0,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="1" Padding="0,6,0,5">R:</Label>
                        <TextBox Grid.Column="2" Width="30" Margin="5" Height="22" Name="TxtGeometryAmbientR" TextChanged="TxtGeometryAmbient_TextChanged"></TextBox>
                        <Label Grid.Column="3" Padding="0,6,0,5">G:</Label>
                        <TextBox Grid.Column="4" Width="30" Margin="5" Height="22" Name="TxtGeometryAmbientG" TextChanged="TxtGeometryAmbient_TextChanged"></TextBox>
                        <Label Grid.Column="5" Padding="0,6,0,5">B:</Label>
                        <TextBox Grid.Column="6" Width="30" Margin="5" Height="22" Name="TxtGeometryAmbientB" TextChanged="TxtGeometryAmbient_TextChanged"></TextBox>
                    </Grid>
                </Border>
                <Label Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Padding="3,5,5,5" HorizontalAlignment="Right">Diffuse Material:</Label>
                <Border Grid.Row="6" Grid.Column="1" BorderBrush="blue" BorderThickness="1" CornerRadius="5" Padding="5,0,3,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="1" Padding="0,6,0,5">R:</Label>
                        <TextBox Grid.Column="2" Width="30" Margin="5" Height="22" Name="TxtGeometryDiffuseR" TextChanged="TxtGeometryDiffuse_TextChanged"></TextBox>
                        <Label Grid.Column="3" Padding="0,6,0,5">G:</Label>
                        <TextBox Grid.Column="4" Width="30" Margin="5" Height="22" Name="TxtGeometryDiffuseG" TextChanged="TxtGeometryDiffuse_TextChanged"></TextBox>
                        <Label Grid.Column="5" Padding="0,6,0,5">B:</Label>
                        <TextBox Grid.Column="6" Width="30" Margin="5" Height="22" Name="TxtGeometryDiffuseB" TextChanged="TxtGeometryDiffuse_TextChanged"></TextBox>
                    </Grid>
                </Border>
                <Label Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Padding="3,5,5,5" HorizontalAlignment="Right">Specular Material:</Label>
                <Border Grid.Row="7" Grid.Column="1" BorderBrush="blue" BorderThickness="1" CornerRadius="5" Padding="5,0,3,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="1" Padding="0,6,0,5">R:</Label>
                        <TextBox Grid.Column="2" Width="30" Margin="5" Height="22" Name="TxtGeometrySpecularR" TextChanged="TxtGeometrySpecular_TextChanged"></TextBox>
                        <Label Grid.Column="3" Padding="0,6,0,5">G:</Label>
                        <TextBox Grid.Column="4" Width="30" Margin="5" Height="22" Name="TxtGeometrySpecularG" TextChanged="TxtGeometrySpecular_TextChanged"></TextBox>
                        <Label Grid.Column="5" Padding="0,6,0,5">B:</Label>
                        <TextBox Grid.Column="6" Width="30" Margin="5" Height="22" Name="TxtGeometrySpecularB" TextChanged="TxtGeometrySpecular_TextChanged"></TextBox>
                    </Grid>
                </Border>
                <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal">
                    <Label Margin="5">Shininess:</Label>
                    <TextBox Margin="5" Height="22" Width="40" HorizontalAlignment="Left" Name="TxtGeometryShininess" TextChanged="TxtGeometryShininess_TextChanged"></TextBox>
                    <CheckBox Margin="25,5,5,5" Name="CbGeometryMaterialUse" Click="CbGeometryMaterialUse_Click" VerticalAlignment="Center">Use Material</CheckBox>
                </StackPanel>
                <GroupBox Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="4" Header="Texture: " Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal">
                            <Label Padding="5,8,5,5">Texture File:</Label>
                            <TextBox Height="22" Width="100" Margin="5" Name="TxtGeometryTexFile" IsReadOnly="True"></TextBox>
                            <Button Margin="5" Width="60" Name="BtnGeometryTexBrowse" Click="BtnGeometryTexBrowse_Click">Browse</Button>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal">
                            <Label HorizontalAlignment="Right" Padding="5,8,0,5">TextureScale X:</Label>
                            <TextBox Height="22" Width="30" Margin="5" HorizontalAlignment="Left" Name="TxtGeometryTexScaleX" TextChanged="TxtGeometryTexScaleX_TextChanged"></TextBox>
                            <Label HorizontalAlignment="Right" Padding="5,8,5,5">TextureScale Y:</Label>
                            <TextBox Height="22" Width="30" Margin="5" HorizontalAlignment="Left" Name="TxtGeometryTexScaleY" TextChanged="TxtGeometryTexScaleY_TextChanged"></TextBox>
                        </StackPanel>
                        <CheckBox Grid.Row="2" Margin="5,8,0,0" Name="CbGeometryTextureUse" Click="CbGeometryTextureUse_Click">Use Texture</CheckBox>
                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal">
                            <Label HorizontalAlignment="Right" Padding="5,8,5,5">Palette File:</Label>
                            <TextBox Height="22" Width="100" Margin="5" Name="TxtGeometryPalette" IsReadOnly="True"></TextBox>
                            <Button Margin="5" Width="60" Name="BtnGeometryPaletteBrowse" Click="BtnGeometryPaletteBrowse_Click">Browse</Button>
                        </StackPanel>
                        <StackPanel  Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal">
                            <Label HorizontalAlignment="Right" Padding="5,8,5,5" Margin="3,0,0,0">VertexColor Intensity:</Label>
                            <TextBox Height="22" Width="40" Margin="5" HorizontalAlignment="Left" Name="TxtGeometryVertColInt" TextChanged="TxtGeometryVertColInt_TextChanged"></TextBox>
                        </StackPanel>
                        <CheckBox  Grid.Row="5" Margin="5" Name="CbGeometryVertColUse" Click="CbGeometryVertColUse_Click" >Use Vertex Colors</CheckBox>
                    </Grid>
                </GroupBox>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="2" Grid.Column="1"  Header="Scene Parameters:" Margin="8" BorderBrush="Blue" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="3" Orientation="Horizontal">
                    <CheckBox Grid.Row="0" Margin="5" Name="CBShowAxes" Click="CBShowAxes_Click">Show Axes</CheckBox>
                    <Label Margin="35,0,0,0">Axes Length </Label>
                    <TextBox Height="22" Width="50" Name="TxtAxesLength" TextChanged="TxtAxesLength_TextChanged"></TextBox>
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="3" Orientation="Horizontal">
                    <Label Margin="20,0,0,0">Labels Size</Label>
                    <TextBox Height="22" Width="50" Name="TxtLabelSize" TextChanged="TxtLabelSize_TextChanged"></TextBox>
                    <Label Margin="20,0,0,0">Arrows Size</Label>
                    <TextBox Height="22" Width="50" Name="TxtArrowSize" TextChanged="TxtArrowSize_TextChanged"></TextBox>
                </StackPanel>
                <CheckBox Grid.Row="2" Margin="5" Name="CBShowGrid" Click="CBShowGrid_Click">Show Grid</CheckBox>
                <StackPanel Grid.Row="3" Margin="3" Orientation="Horizontal">
                    <Label Margin="2,3,3,3">Grid Max Size</Label>
                    <TextBox Height="22" Width="50" Margin="2,0,0,0" Name="TxtGridSize" TextChanged="TxtGridSize_TextChanged"></TextBox>
                    <Label Margin="12,0,0,0">Grid Interval</Label>
                    <TextBox Height="22" Width="50" Margin="2,0,0,0" Name="TxtGridInterval" TextChanged="TxtGridInterval_TextChanged"></TextBox>
                </StackPanel>
                <StackPanel Grid.Row="4" Margin="3" Orientation="Horizontal">
                    <CheckBox Grid.Row="0" Margin="5,5,0,5" Name="CBShowXYGrid" Click="CBShowXYGrid_Click">Show XYGrid</CheckBox>
                    <CheckBox Grid.Row="0" Margin="10,5,0,5" Name="CBShowXZGrid" Click="CBShowXZGrid_Click">Show XZGrid</CheckBox>
                    <CheckBox Grid.Row="0" Margin="10,5,0,5" Name="CBShowYZGrid" Click="CBShowYZGrid_Click">Show YZGrid</CheckBox>
                </StackPanel>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="3" Grid.Column="1"  Header="Lights:" Margin="8" BorderBrush="Blue" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <CheckBox Grid.Row="0" Margin="20,5,0,5" Name ="CBDirLight"  Click="CBDirLight_Click">Show Directional Light</CheckBox>
                <CheckBox Grid.Row="1" Margin="20,5,0,5" Name="CBPointLight" Click="CBPointLight_Click">Show Point Light</CheckBox>
                <CheckBox Grid.Row="2" Margin="20,5,0,5" Name="CBSpotLight" Click="CBSpotLight_Click">Show Spot Light</CheckBox>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
