<Window x:Class="Audio_Spectrum.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Audio_Vieuwer"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="Open" Name="mnuOpen" Click="mnuOpen_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Exit" Name="mnuExit" Click="mnuExit_Click"></MenuItem>
            </MenuItem>
        </Menu>
        <Border Grid.Row="1" BorderBrush="Blue" BorderThickness="3" Margin="5">
            <Canvas x:Name="canvas1">
                <Image x:Name="image1"></Image>
        </Canvas>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Grid.Row="3" Margin="80,10,10,10" Width="80" FontSize="14" FontWeight="Bold" Name="btnPlay" Click="btnPlay_Click">START</Button>
            <Label FontSize="12" VerticalContentAlignment="Center" Margin="100,10,10,10">Sensitivity</Label>
            <Slider Margin="10" Width="150" Name="sldSensitivity" ValueChanged="sldSensitivity_ValueChanged" Minimum="1000000" Maximum="10000000" Value="5000000" VerticalAlignment="Center" IsDirectionReversed="True"></Slider>
        </StackPanel>
    </Grid>
</Window>
