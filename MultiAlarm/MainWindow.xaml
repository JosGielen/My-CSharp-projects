<Window x:Class="MultiAlarm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MultiAlarm"
        mc:Ignorable="d"
        xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
		Title="ALARMS" Height="340" Width="550" Icon="Icon1.ico"
        ShowInTaskbar="False" WindowStyle="ToolWindow" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="0" Grid.ColumnSpan="2" Margin="15,0,15,5" AutoGenerateColumns="False" IsReadOnly="True" 
                  Name="AlarmDataGrid" CanUserReorderColumns="False" VerticalScrollBarVisibility="Visible"
                  EnableRowVirtualization="False" IsSynchronizedWithCurrentItem="True" HorizontalScrollBarVisibility="Disabled"
                  HorizontalGridLinesBrush="Gray" VerticalGridLinesBrush="Gray">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Enable" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Name="CBEnabled" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      IsChecked="{Binding Path=Enabled, Mode=TwoWay }" Click="CBEnabled_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Time" Width="0.25*" Binding="{Binding Path=Time}"></DataGridTextColumn>
                <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Path=Message}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <GroupBox Header="New Alarm" Grid.Row="1" Grid.ColumnSpan="2" Margin="15,10,15,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="10,5,10,5" Orientation="Horizontal" >
                    <xceed:AutoSelectTextBox Name="TxtHours" FontSize="16" FontWeight="Bold" Height="25" MaxLength="2" 
                                     AutoSelectBehavior="OnFocus" MinWidth="28" MinHeight="25" TabIndex="0" 
                                     AutoMoveFocus="True">00</xceed:AutoSelectTextBox>
                    <Label FontSize="16" FontWeight="Bold" >:</Label>
                    <xceed:AutoSelectTextBox Name="TxtMinutes" FontSize="16" FontWeight="Bold" Height="25" MaxLength="2"
                                     AutoSelectBehavior="OnFocus" MinWidth="28" MinHeight="25" TabIndex="1" 
                                     AutoMoveFocus="True">00</xceed:AutoSelectTextBox>
                    <Label FontSize="16" FontWeight="Bold">:</Label>
                    <xceed:AutoSelectTextBox Name="TxtSeconds" FontSize="16" FontWeight="Bold" Height="25" MaxLength="2" 
                                     AutoSelectBehavior="OnFocus" MinWidth="28" MinHeight="25" TabIndex="2"
                                     AutoMoveFocus="True" >00</xceed:AutoSelectTextBox>
                    <TextBox x:Name="TxtMessage" Margin="8,3,3,3" Height="25" Width="300"></TextBox>
                    <Button Name="BtnAdd" Margin="5" Width="40" FontSize="14" MinHeight="25" Click="BtnAdd_Click">Add</Button>
                </StackPanel>
            </Grid>
        </GroupBox>
        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="15,5,15,5" Orientation="Horizontal" HorizontalAlignment="Center" >
            <Button Name="BtnRemove" Margin="15,5" FontSize="14" Width="180" MinHeight="25" Click="BtnRemove_Click">Remove Unchecked Alarms</Button>
            <Button Name="BtnOK" Margin="15,5" FontSize="14" Width="70" MinHeight="25" Click="BtnOK_Click" IsDefault="True">OK</Button>
            <Button Name="BtnCancel" Margin="15,5" FontSize="14" Width="70" MinHeight="25" Click="BtnCancel_Click" IsCancel="True">CANCEL</Button>
        </StackPanel>
    </Grid>
</Window>
