<Window x:Class="Matrix_Rain.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Matrix_Rain"
        mc:Ignorable="d"
        Title="CLICK TO START" Height="800" Width="800" Closing="Window_Closing" Loaded="Window_Loaded"
        MouseDown="Window_MouseDown" MouseMove="Window_MouseMove" KeyDown="Window_KeyDown"
        Top="0" Left="0" WindowStyle="None" WindowStartupLocation="Manual" 
        ShowInTaskbar="False" ResizeMode="NoResize" AllowsTransparency="False">
    <Grid>
        <Canvas Name="Canvas1" Background="Black">
            <Canvas.BitmapEffect>
                <BlurBitmapEffect Radius="5"></BlurBitmapEffect>
            </Canvas.BitmapEffect>
        </Canvas>
    </Grid>
</Window>
