<Window x:Class="Box2D_Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Box2D_App"
        mc:Ignorable="d"
        Title="MainWindow" Height="1000" Width="1800" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="5" BorderBrush="Blue" BorderThickness="2">
            <Canvas Name="canvas1"></Canvas>
        </Border>
        <StackPanel Grid.Row="1" Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Label Margin="5">Bullet Speed:</Label>
            <Slider Width="150" Margin="5,5,5,5" Name="sldSpeed" Minimum="0" Maximum="300" Value="100" TickFrequency="20" TickPlacement="Both" LargeChange="15" SmallChange="5" IsSnapToTickEnabled="True"></Slider>
            <TextBox Width="50" Margin="5" FontSize="14" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="{Binding ElementName=sldSpeed, Path=Value}"></TextBox>
            <Button Width="60" Margin="150,5,150,5" Name="btnFire" Click="btnFire_Click">FIRE</Button>
            <Button Width="60" Margin="5,5,150,5" Name="btnReset" Click="btnReset_Click">RESET</Button>
        </StackPanel>
    </Grid>
</Window>
