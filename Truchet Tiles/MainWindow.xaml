<Window x:Class="Truchet_Tiles.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Truchet_Tiles"
        mc:Ignorable="d"
        Title="MainWindow" Height="886" Width="836" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="15" BorderBrush="Blue" BorderThickness="3.0">
            <Canvas x:Name="canvas1" ClipToBounds="True"></Canvas>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <RadioButton Margin="5,5,40,5" x:Name="RbTriangles" GroupName="type" Click="RbType_Click" IsChecked="True">Triangles</RadioButton>
            <RadioButton Margin="5,5,40,5" x:Name="RbArcs" GroupName="type" Click="RbType_Click">Arcs</RadioButton>
            <RadioButton Margin="5" x:Name="RbLines" GroupName="type" Click="RbType_Click">Lines</RadioButton>
        </StackPanel>
    </Grid>
</Window>
