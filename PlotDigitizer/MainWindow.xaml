<Window x:Class="PlotDigitizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlotDigitizer"
        mc:Ignorable="d"
        Title="MainWindow" Height="775" Width="800" 
        Loaded="Window_Loaded" 
        MouseDown="Window_MouseDown" 
        MouseMove="Window_MouseMove" 
        SizeChanged="Window_SizeChanged" 
        WindowState="Maximized">
    <DockPanel >
        <Menu DockPanel.Dock="Top" >
            <MenuItem Header="File" Name="MenuFile" Width="50">
                <MenuItem Header="Open Image..." Name="MenuOpen" Click="MenuOpen_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Save Data..." Name="MenuSaveData" Click="MenuSaveData_Click"></MenuItem>
                <MenuItem Header="Copy Data" Name="MenuCopyData" Click="MenuCopyData_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Exit" Name="MenuExit" Click="MenuExit_Click"></MenuItem>
            </MenuItem>
            <MenuItem Header="RESET" Name="MenuReset" Click="MenuReset_Click"></MenuItem>
        </Menu>
        <Grid DockPanel.Dock="Right" Width="200">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <GroupBox Grid.Row="0" Header="X-AXIS :" Margin="5,10,5,5" Padding="3" FontWeight="Bold" BorderBrush="Blue">
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Padding="5,0" FontWeight="Normal" >X</Label>
                    <Label Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Padding="5,0" FontWeight="Normal" >Y</Label>
                    <Button Grid.Row="1" Grid.Column="0" Margin="3,0,3,3" Name="BtnXOrigin" Click="BtnXOrigin_Click"  FontWeight="Normal">Origin:</Button>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="3,0,3,3" Name="TxtXOriginX" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <TextBox Grid.Row="1" Grid.Column="2" Margin="3,0,3,3" Name="TxtXOriginY" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <Label Grid.Row="2" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Value:</Label>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="TxtXOriginValue" FontWeight="Normal"></TextBox>
                    <Button Grid.Row="3" Grid.Column="0" Margin="3" Name="BtnXMax" Click="BtnXMax_Click"  FontWeight="Normal">Max.:</Button>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="3" Name="TxtXMaxX" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <TextBox Grid.Row="3" Grid.Column="2" Margin="3" Name="TxtXMaxY" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <Label Grid.Row="4" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Value:</Label>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="TxtXMaxValue" FontWeight="Normal"></TextBox>
                    <RadioButton  Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="3" IsChecked="True" Name="RbXLinear" FontWeight="Normal">Linear</RadioButton>
                    <RadioButton Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="RbXLog" FontWeight="Normal">Logarithmic</RadioButton>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="1" Header="Y-AXIS :" Margin="5" Padding="3" FontWeight="Bold" BorderBrush="Blue">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Padding="5,0" FontWeight="Normal" >X</Label>
                    <Label Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Padding="5,0" FontWeight="Normal" >Y</Label>
                    <Button Grid.Row="1" Grid.Column="0" Margin="3,0,3,3" Name="BtnYOrigin" Click="BtnYOrigin_Click"  FontWeight="Normal">Origin:</Button>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="3,0,3,3" Name="TxtYOriginX" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <TextBox Grid.Row="1" Grid.Column="2" Margin="3,0,3,3" Name="TxtYOriginY" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <Label Grid.Row="2" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Value:</Label>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="TxtYOriginValue" FontWeight="Normal"></TextBox>
                    <Button Grid.Row="3" Grid.Column="0" Margin="3" Name="BtnYMax" Click="BtnYMax_Click"  FontWeight="Normal">Max.:</Button>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="3" Name="TxtYMaxX" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <TextBox Grid.Row="3" Grid.Column="2" Margin="3" Name="TxtYMaxY" FontWeight="Normal" IsReadOnly="True" IsTabStop="False"></TextBox>
                    <Label Grid.Row="4" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Value:</Label>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="TxtYMaxValue" FontWeight="Normal"></TextBox>
                    <RadioButton  Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="3" IsChecked="True" Name="RbYLinear" FontWeight="Normal">Linear</RadioButton>
                    <RadioButton Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="RbYLog" FontWeight="Normal">Logarithmic</RadioButton>
                </Grid>
            </GroupBox>
            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="5,15,5,5" Height="30" Width="130" FontWeight="Bold" IsEnabled="False" Name="BtnImgPix" Click="BtnImgPix_Click">Use Image Pixel Sizes</Button>
            <GroupBox Grid.Row="3" Header="DATA Points :" Margin="5,15,5,5" Padding="3" BorderBrush="Blue">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0">Data count:</Label>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="3" Name="TxtDataCount" IsReadOnly="True" IsTabStop="False">0</TextBox>
                    <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5,5,5,10" FontWeight="Bold" Height="30" Name="BtnAddData" IsEnabled="False" Click="BtnAddData_Click">Add Data Points</Button>
                    <Label Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" Padding="0">X</Label>
                    <Label Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" Padding="0">Y</Label>
                    <ScrollViewer Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto" >
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Row="3" Grid.Column="0" Margin="3,3,0,3" IsReadOnly="True" Name="TxtDataPointsX" HorizontalContentAlignment="Center" IsTabStop="False"></TextBox>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,3,3,3" IsReadOnly="True" Name="TxtDataPointsY" HorizontalContentAlignment="Center" IsTabStop="False"></TextBox>
                        </Grid>
                    </ScrollViewer>
                    <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="5,10,5,5" Height="30" FontWeight="Bold" Name="BtnClearData" IsEnabled="False" Click="BtnClearData_Click">Clear Data Points</Button>
                </Grid>
            </GroupBox>
        </Grid>
        <Border BorderBrush="DarkGray" BorderThickness="2">
            <Canvas Name="Canvas1" Background="DarkGray">
                <Image Name="Image1" ScrollViewer.VerticalScrollBarVisibility="Disabled" Stretch="Uniform"></Image>
            </Canvas>
        </Border>
    </DockPanel>
</Window>
