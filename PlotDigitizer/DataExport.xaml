<Window x:Class="PlotDigitizer.DataExport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlotDigitizer"
        mc:Ignorable="d"
        Title="DataExport" Height="400" Width="450" WindowStyle="ToolWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Margin="5" FontWeight="Bold" >Graph Title:</Label>
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Name="TxtGraphTitle"></TextBox>
        <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Header="X-AXIS :" Margin="5" Padding="3" FontWeight="Bold" BorderBrush="Blue">
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Label:</Label>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="3" Name="TxtXLabel" FontWeight="Normal"></TextBox>
                <Label Grid.Row="1" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Origin:</Label>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="3" Name="TxtXMinValue" FontWeight="Normal" IsReadOnly="True"></TextBox>
                <Label Grid.Row="1" Grid.Column="2" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Maximum:</Label>
                <TextBox Grid.Row="1" Grid.Column="3" Margin="3" Name="TxtXMaxValue" FontWeight="Normal" IsReadOnly="True"></TextBox>
                <Label Grid.Row="2" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Scale:</Label>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="TxtXScale" FontWeight="Normal" IsReadOnly="True"></TextBox>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Header="Y-AXIS :" Margin="5" Padding="3" FontWeight="Bold" BorderBrush="Blue">
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Label:</Label>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="3" Name="TxtYLabel" FontWeight="Normal"></TextBox>
                <Label Grid.Row="1" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Origin:</Label>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="3" Name="TxtYMinValue" FontWeight="Normal" IsReadOnly="True"></TextBox>
                <Label Grid.Row="1" Grid.Column="2" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Maximum:</Label>
                <TextBox Grid.Row="1" Grid.Column="3" Margin="3" Name="TxtYMaxValue" FontWeight="Normal" IsReadOnly="True"></TextBox>
                <Label Grid.Row="2" Grid.Column="0" Margin="3" Height="22" Padding="5,2,5,0" FontWeight="Normal">Scale:</Label>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="3" Name="TxtYScale" FontWeight="Normal" IsReadOnly="True"></TextBox>
            </Grid>
        </GroupBox>
        <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" FontWeight="Bold" HorizontalAlignment="Center">Data:</Label>
            <Label Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Padding="0">X</Label>
            <Label Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Padding="0">Y</Label>
            <ScrollViewer Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Row="3" Grid.Column="0" Margin="3,3,0,3" Name="TxtDataPointsX" HorizontalContentAlignment="Center" IsReadOnly="True"></TextBox>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,3,3,3" Name="TxtDataPointsY" HorizontalContentAlignment="Center" IsReadOnly="True"></TextBox>
                </Grid>
            </ScrollViewer>
        </Grid>
        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" Width="150" Name="BtnInfo" Click="BtnInfo_Click">Copy Data and Graph Info</Button>
        <Button Grid.Row="3" Grid.Column="3" Margin="10" Width="150" Name="BtnData" Click="BtnData_Click">Copy Data only</Button>
        <Button Grid.Row="4" Grid.Column="3" Margin="10" Height="25" Width="80" Name="BtnCancel" Click="BtnCancel_Click">CANCEL</Button>
    </Grid>
</Window>
